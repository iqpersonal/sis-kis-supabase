{
  "expo": {
    "name": "KiS-SiS",
    "slug": "sis-mobile",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "sis-mobile",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5edd2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kis.sis"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f5edd2",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.kis.sis",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2563eb"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow KiS SiS to access camera for barcode scanning and product photos"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow KiS SiS to access photos for product images"
        }
      ],
      "expo-sharing"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b642c8c1-170d-4447-a640-14278dafc05f"
      }
    }
  }
}
